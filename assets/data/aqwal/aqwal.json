[
  {
    "id": 1,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لَا تَسْتَحِ مِنْ إِعْطَاءِ الْقَلِيلِ فَإِنَّ الْحِرْمَانَ أَقَلُّ مِنْهُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 67"
  },
  {
    "id": 2,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الصَّبْرُ صَبْرَانِ: صَبْرٌ عَلَى مَا تَكْرَهُ وَصَبْرٌ عَمَّا تُحِبُّ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 289"
  },
  {
    "id": 3,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ أَطَالَ الْأَمَلَ أَسَاءَ الْعَمَلَ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 30"
  },
  {
    "id": 4,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "قِيمَةُ كُلِّ امْرِئٍ مَا يُحْسِنُهُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 81"
  },
  {
    "id": 5,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الْعِلْمُ خَيْرٌ مِنَ الْمَالِ، الْعِلْمُ يَحْرُسُكَ وَأَنْتَ تَحْرُسُ الْمَالَ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 147"
  },
  {
    "id": 6,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "أَكْثَرُ مَصَارِعِ الْعُقُولِ تَحْتَ بَرْقِ الْمَطَامِعِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 219"
  },
  {
    "id": 7,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ ظَلَمَ عَبْداً مِنْ عَبِيدِ اللَّهِ كَانَ اللَّهُ خَصْمَهُ دُونَ عَبْدِهِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 267"
  },
  {
    "id": 8,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الصَّدَقَةُ دَوَاءٌ مُنْجِحٌ وَأَعْمَالُ الْعِبَادِ فِي عَاجِلِهِمْ نُصْبُ أَعْيُنِهِمْ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 243"
  },
  {
    "id": 9,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ نَظَرَ فِي عَيْبِ نَفْسِهِ اشْتَغَلَ عَنْ عَيْبِ غَيْرِهِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 349"
  },
  {
    "id": 10,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لَا يَحْزُنْكَ ظُلْمُ الظَّالِمِ فَإِنَّهُ يَسْعَى فِي مَهْلَكَةٍ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 248"
  },
  {
    "id": 11,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "مَا شَاوَرَ قَوْمٌ إِلَّا هُدُوا إِلَى رُشْدِهِمْ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 12,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "الْعَجْزُ مِنْكَ أَنْ تَسْتَنْظِرَ الْقَضَاءَ فَإِذَا نَزَلَ بِكَ اضْطَرَبْتَ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 13,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "عَجِبْتُ لِمَنْ يَتَفَكَّرُ فِي مَأْكُولِهِ كَيْفَ لَا يَتَفَكَّرُ فِي مَعْقُولِهِ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 14,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "الْخُلُقُ الْحَسَنُ يُثْمِرُ الْمَوَدَّةَ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 15,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "إِذَا أَقْبَلَتِ الدُّنْيَا عَلَى قَوْمٍ أَعَارَتْهُمْ مَحَاسِنَ غَيْرِهِمْ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 16,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "إِنَّ شِيعَتَنَا مَنْ سَلِمَتْ قُلُوبُهُمْ مِنْ كُلِّ غِشٍّ وَغِلٍّ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 17,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "لَا تَقُولُوا بِأَلْسِنَتِكُمْ مَا لَا تَعْلَمُونَ فَإِنَّ أَكْثَرَ الْخَطَايَا فِي ذَلِكَ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 18,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "مَنْ كَانَ فِي طَاعَةِ اللَّهِ كَانَ اللَّهُ مَعَهُ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 19,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "اللَّهُمَّ أَنْتَ مُتَعَالِي الْمَكَانِ عَظِيمُ الْجَبَرُوتِ شَدِيدُ الْمِحَالِ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "دعاء عرفة",
    "reference": ""
  },
  {
    "id": 20,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "إِنَّ الْحَيَاةَ عَقِيدَةٌ وَجِهَادٌ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 21,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "أَعْظَمُ النَّاسِ قَدْراً مَنْ تَرَكَ مَا لَا يَعْنِيهِ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "الصحيفة السجادية",
    "reference": ""
  },
  {
    "id": 22,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "وَأَمَّا حَقُّ اللِّسَانِ فَإِكْرَامُهُ عَنِ الْخَنَا وَتَعْوِيدُهُ عَلَى الْخَيْرِ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "رسالة الحقوق",
    "reference": ""
  },
  {
    "id": 23,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "وَأَمَّا حَقُّ الْعَيْنَيْنِ فَغَضُّهُمَا عَمَّا لَا يَحِلُّ وَالِاعْتِبَارُ بِمَا تَرَيَانِ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "رسالة الحقوق",
    "reference": ""
  },
  {
    "id": 24,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "وَأَمَّا حَقُّ الْقَدَمَيْنِ فَأَنْ لَا تَمْشِيَ بِهِمَا فِي مَعْصِيَةٍ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "رسالة الحقوق",
    "reference": ""
  },
  {
    "id": 25,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "مَنْ عَمِلَ بِمَا افْتَرَضَ اللَّهُ عَلَيْهِ فَهُوَ مِنْ أَعْبَدِ النَّاسِ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 26,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "مَنْ أَصْبَحَ لَا يَهُمُّ بِظُلْمِ أَحَدٍ غُفِرَ لَهُ مَا اجْتَرَمَ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 27,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "الْعِلْمُ نُورٌ يَقْذِفُهُ اللَّهُ فِي قَلْبِ مَنْ يَشَاءُ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 28,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "لَا يَذْهَبُ الْحَيَاءُ مِنَ الْإِيمَانِ وَهُمَا جَمِيعاً لَا يَذْهَبَانِ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 29,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "إِنَّ مِنْ أَشَدِّ الذُّنُوبِ مَا اسْتَخَفَّ صَاحِبُهُ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 30,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "لَا تَتِمُّ الْمَكَارِمُ إِلَّا بِالسَّخَاءِ وَالْحِلْمِ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 31,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "مَنْ كَانَ مُؤْمِناً كَانَ حُلْواً وَإِنْ لَمْ يَكُنْ حُلْواً فَلَيْسَ بِمُؤْمِنٍ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 32,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "إِنَّ اللَّهَ لَا يَقْبَلُ الْعَمَلَ إِلَّا بِالْوَرَعِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 33,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "الْعَالِمُ بِزَمَانِهِ لَا تَهْجُمُ عَلَيْهِ اللَّوَابِسُ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 34,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "اكْتُمُوا الْحَسَنَةَ كَمَا تَكْتُمُونَ السَّيِّئَةَ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 35,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "إِنَّ الْقُلُوبَ تَمَلُّ كَمَا تَمَلُّ الْأَبْدَانُ فَابْتَغُوا لَهَا طَرَائِفَ الْحِكْمَةِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 36,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "لَا يَزَالُ الْعَبْدُ فِي سَعَةٍ مِنَ الْأَمْرِ مَا دَامَ فِي عِبَارَةِ الْأَخِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 37,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "إِنَّ الْإِيمَانَ أَشَدُّ مِنَ الْحَدِيدِ وَأَثْبَتُ مِنَ الْجِبَالِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 38,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "مَنْ سَاءَ خُلُقُهُ عَذَّبَ نَفْسَهُ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 39,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "التَّوَدُّدُ إِلَى النَّاسِ نِصْفُ الْعَقْلِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 40,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "إِنَّ لِلْقَلْبِ نُزُوعاً وَإِقْبَالاً وَإِدْبَاراً فَإِنْ أَقْبَلَ فَعَلَيْكُمْ بِمَا تَهْوَى",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 41,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "إِيَّاكَ وَمُصَاحَبَةَ الْفَاجِرِ فَإِنَّهُ يَبِيعُكَ بِالتَّافِهِ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 42,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "الْعُقُولُ أَئِمَّةُ الْأَفْكَارِ وَالْأَفْكَارُ أَئِمَّةُ الْقُلُوبِ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 43,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "الْمَجْدُ فِي الْعَفْوِ وَالرِّيَاسَةُ فِي الْحِلْمِ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 44,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "صَاحِبُ النِّعْمَةِ يَجِبُ عَلَيْهِ التَّوْسِعَةُ عَلَى عِيَالِهِ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 45,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "أَقَلُّ النَّاسِ رَاحَةً الْحَسُودُ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 46,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "مَنْ تَذَكَّرَ مُصِيبَتَنَا فَلَهُ أَجْرُ أَلْفِ شَهِيدٍ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 47,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "الصِّدِيقُ مَنِ اتَّقَى اللَّهَ فِي الْأَمْرِ وَالنَّهْيِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 48,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "مَنْ لَمْ يَشْكُرِ اللَّهَ فِي الْيَسِيرِ لَمْ يَشْكُرْهُ فِي الْكَثِيرِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 49,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "إِنَّ اللَّهَ أَمَرَ بِالْقَصْدِ وَالْعَدْلِ وَالْإِحْسَانِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 50,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "لَيْسَ الْعَافِيَةُ أَنْ لَا تُبْتَلَى وَلَكِنَّ الْعَافِيَةَ أَنْ تَصْبِرَ عِنْدَ الْبَلَاءِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 51,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "الْعَدَالَةُ هِيَ الْعِفَّةُ وَالصَّلَاحُ فِي الْأُمُورِ الدِّينِيَّةِ",
    "narrator": "السيد علي السيستاني",
    "source": "الفقه للمغتربين",
    "reference": ""
  },
  {
    "id": 52,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "يَجِبُ عَلَى الْمُكَلَّفِ تَعْلِيمُ الْأَحْكَامِ الشَّرْعِيَّةِ بِقَدْرِ الْحَاجَةِ",
    "narrator": "السيد علي السيستاني",
    "source": "منهاج الصالحين",
    "reference": ""
  },
  {
    "id": 53,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "الْإِسْلَامُ هُوَ دِينُ الْفِطْرَةِ وَالْحَضَارَةِ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 54,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "التَّقْوَى أَفْضَلُ مَا يَتَزَوَّدُ بِهِ الْإِنْسَانُ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 55,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "الْإِنْسَانُ هُوَ الْكَائِنُ الْوَحِيدُ الَّذِي يَصْنَعُ نَفْسَهُ بِنَفْسِهِ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 56,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "التَّارِيخُ لَيْسَ مَاضِياً وَحَسْبُ بَلْ هُوَ مَاضٍ يُحَدِّدُ الْمُسْتَقْبَلَ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 57,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "لَا يُمْكِنُ لِلْإِسْلَامِ أَنْ يُعْطِيَ شَيْئاً مَا لَمْ يُعْطِ الْقُرْآنَ كُلَّ شَيْءٍ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "المدرسة القرآنية",
    "reference": ""
  },
  {
    "id": 58,
    "category": "حكم وأقوال العلماء",
    "categoryId": "scholars",
    "text": "الْعَالِمُ الرَّبَّانِيُّ هُوَ الَّذِي يَكُونُ قَرِيباً مِنَ اللَّهِ بَعِيداً عَنِ الدُّنْيَا",
    "narrator": "الشيخ محمد حسين كاشف الغطاء",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 59,
    "category": "حكم وأقوال العلماء",
    "categoryId": "scholars",
    "text": "إِنَّ الْوَقْتَ سَيْفٌ فَإِنْ لَمْ تَقْطَعْهُ قَطَعَكَ",
    "narrator": "الشيخ محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 60,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "الْوَحْدَةُ الْإِسْلَامِيَّةُ فَرِيضَةٌ شَرْعِيَّةٌ لَا تَخْضَعُ لِلظُّرُوفِ",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 61,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "الْقُرْآنُ هُوَ مِيثَاقُ الْأُمَّةِ وَأَسَاسُ وِحْدَتِهَا",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 62,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لَا يَزْهَدَنَّكَ فِي الْمَعْرُوفِ عَدَمُ شُكْرِ الشَّاكِرِ فَقَدْ يُشْكَرُ بِمَا لَا يَبْلُغُهُ شُكْرُهُمْ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 196"
  },
  {
    "id": 63,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لَا تَكُنْ مِمَّنْ يَرْجُو الْآخِرَةَ بِغَيْرِ عَمَلٍ وَيُرَجِّي التَّوْبَةَ بِطُولِ الْأَمَلِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 150"
  },
  {
    "id": 64,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "إِذَا تَمَّ الْعَقْلُ نَقَصَ الْكَلَامُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 67"
  },
  {
    "id": 65,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الْعِلْمُ مَقْرُونٌ بِالْعَمَلِ فَمَنْ عَلِمَ عَمِلَ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 366"
  },
  {
    "id": 66,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لَا تَسْتَصْغِرَنَّ عَدُوّاً وَلَا تَسْتَعْظِمَنَّ ذَنْباً",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 116"
  },
  {
    "id": 67,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "عَجِبْتُ لِمَنِ اشْتَرَى الْمَمْلُوكَ بِمَالِهِ وَلَمْ يَشْتَرِ الْحُرَّ بِمَعْرُوفِهِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 34"
  },
  {
    "id": 68,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ ضَيَّعَهُ الْأَقْرَبُ أُوتِيَ مِنَ الْأَبْعَدِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 9"
  },
  {
    "id": 69,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "مَنْ تَوَكَّلَ عَلَى اللَّهِ كَفَاهُ وَمَنْ لَجَأَ إِلَيْهِ وُقِيَ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 70,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "لَيْسَ الْعَبْدُ بِعَاقِلٍ حَتَّى يَكُونَ فِيهِ ثَلَاثٌ: يُصْلِحُ مَعِيشَتَهُ وَيُقِيمُ دِينَهَ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 71,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "إِنَّ الْكَرِيمَ إِذَا قَدَرَ عَفَا",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 72,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "الصَّبْرُ عَلَى الْأَذَى مِنْ أَفْضَلِ أَعْمَالِ الْأَبْرَارِ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 73,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "وَلِلَّهِ عَلَيْكَ حُقُوقٌ فِي كُلِّ حَرَكَةٍ تَحَرَّكْتَهَا",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "رسالة الحقوق",
    "reference": ""
  },
  {
    "id": 74,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "الْإِسْلَامُ بَدَأَ غَرِيباً وَسَيَعُودُ غَرِيباً فَطُوبَى لِلْغُرَبَاءِ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 75,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "لَا تَسْأَلْ مَا لَا يَكُونُ فَدَعْ مَا لَا يَعْنِيكَ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 76,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "مَنْ جَلَسَ مَجْلِسَ الْعِلْمِ اغْتَنَمَ فُرْصَةَ الْحَيَاةِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 77,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "الْإِيمَانُ هُوَ النُّورُ الَّذِي يُحَوِّلُ الْوُجُودَ إِلَى حَيَاةٍ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 78,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "كُلُّ مَا فِي الْكَوْنِ يَشْهَدُ بِوُجُودِ اللَّهِ وَعَظَمَتِهِ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "المرسل والرسول والرسالة",
    "reference": ""
  },
  {
    "id": 79,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "الْعِلْمُ نُورٌ يَمْلَأُ الْقَلْبَ فَلَا يَبْقَى مَعَهُ ظَلَامٌ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 80,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "الْحَيَاةُ مَيْدَانٌ لِلْعَمَلِ لَا مَيْدَانٌ لِلْأَمَلِ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 81,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "الْقُرْآنُ كِتَابُ الْحَيَاةِ يَمْنَحُنَا الرُّؤْيَةَ وَالْبَصِيرَةَ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 82,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "اعْمَلْ لِآخِرَتِكَ كَأَنَّكَ تَمُوتُ غَداً وَاعْمَلْ لِدُنْيَاكَ كَأَنَّكَ تَعِيشُ أَبَداً",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 83,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "لَا تَنْظُرْ إِلَى صِغَرِ الذَّنْبِ وَلَكِنْ انْظُرْ إِلَى عِظَمِ مَنْ عَصَيْتَ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 84,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "الْإِسْلَامُ يَبْدَأُ مِنَ الْفَرْدِ لِيَصِلَ إِلَى الْمُجْتَمَعِ",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 85,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "الْعَدْلُ أَسَاسُ الْحُكْمِ وَالْحَيَاةِ",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 86,
    "category": "حكم وأقوال العلماء",
    "categoryId": "scholars",
    "text": "لَيْسَ كُلُّ مَا يَعْلَمُهُ الْمَرْءُ يَسْتَطِيعُ أَنْ يُعَبِّرَ عَنْهُ",
    "narrator": "الشيخ محمد حسين كاشف الغطاء",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 87,
    "category": "حكم وأقوال العلماء",
    "categoryId": "scholars",
    "text": "الْأَخْلَاقُ لَيْسَتْ كَلِمَاتٍ تُقَالُ بَلْ أَعْمَالٌ تُقَامُ",
    "narrator": "الشيخ محمد حسين كاشف الغطاء",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 88,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "إِنَّ اللَّهَ لَمْ يَبْعَثْ نَبِيًّا إِلَّا بِصِدْقِ الْحَدِيثِ وَأَدَاءِ الْأَمَانَةِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 89,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "لَا تَدَعُوا الْعَمَلَ لِلصَّلَاحِ فَإِنَّ الصَّلَاحَ لَا يَتَقَدَّمُ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 90,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "إِنَّ اللَّهَ يُحِبُّ الْحَيِيَّ الْحَلِيمَ الْمُتَعَفِّفَ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 91,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "لَا تَحْقِرَنَّ مِنَ الْخَيْرِ شَيْئاً فَلَعَلَّهُ يَمْحُو عَنْكَ مَا لَا تَعْلَمُ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "الصحيفة السجادية",
    "reference": ""
  },
  {
    "id": 92,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "لِلْعَالِمِ ثَلَاثُ عَلَامَاتٍ: الْعِلْمُ وَالْحِلْمُ وَالصَّمْتُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "غرر الحكم",
    "reference": ""
  },
  {
    "id": 93,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الرَّحِيمُونَ يُرْحَمُونَ فَارْحَمُوا مَنْ فِي الْأَرْضِ يَرْحَمْكُمْ مَنْ فِي السَّمَاءِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 94,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ لَمْ يَرْحَمْ لَمْ يُرْحَمْ وَمَنْ لَمْ يَغْفِرْ لَمْ يُغْفَرْ لَهُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 95,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "لَسْنَا شِيعَةً حَتَّى نَكُونَ فِيمَنْ يُقَالُ لَهُمْ: اتَّقُوا اللَّهَ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 96,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "وَأَمَّا حَقُّ النَّفْسِ عَلَيْكَ فَأَنْ تَسْتَوْفِيَهَا طَاعَةَ اللَّهِ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "رسالة الحقوق",
    "reference": ""
  },
  {
    "id": 97,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "ثَلَاثَةٌ هُنَّ رُءُوسُ الْخَطَايَا: الْحِرْصُ وَالْكِبْرُ وَالْحَسَدُ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 98,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "الْحِلْمُ غِطَاءُ الْعَيْبِ وَالرِّفْقُ يَمْنَعُ الْفَوْتَ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 99,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "رَحِمَ اللَّهُ مَنْ أَحْيَا أَمْرَنَا",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 100,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "فَإِنَّ الْأَرْضَ لَا تَخْلُو مِنْ حُجَّةٍ لِلَّهِ عَلَى خَلْقِهِ",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للطوسي",
    "reference": ""
  },
  {
    "id": 101,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "أَكْثِرُوا الدُّعَاءَ بِتَعْجِيلِ الْفَرَجِ فَإِنَّ ذَلِكَ فَرَجُكُم",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للنعماني",
    "reference": ""
  },
  {
    "id": 102,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "لَوْ تَصِلُونَ بِاللَّهِ فِي الْأُمُورِ لَكَفَاكُمُ اللَّهُ الْأُمُورَ",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للطوسي",
    "reference": ""
  },
  {
    "id": 103,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "كُلُّ مَنْ مَاتَ بِغَيْرِ إِمَامٍ مَاتَ مِيتَةً جَاهِلِيَّةً",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للنعماني",
    "reference": ""
  },
  {
    "id": 104,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "إِنَّا غَيْرُ مُهْمِلِينَ لِمُرَاعَاتِكُمْ وَلَا نَاسِينَ لِذَكَرِكُمْ",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للطوسي",
    "reference": ""
  },
  {
    "id": 105,
    "category": "الإمام المهدي (عج)",
    "categoryId": "imam_mahdi",
    "text": "أَطِيعُوا اللَّهَ وَرَسُولَهُ فِي أَمْرِنَا فَإِنَّ ذَلِكَ نَجَاتُكُمْ",
    "narrator": "الإمام المهدي المنتظر (عج)",
    "source": "الغيبة للنعماني",
    "reference": ""
  },
  {
    "id": 106,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الْإِنْصَافُ مِرْآةُ الْعَقْلِ وَالتَّوَاضُعُ نِتَاجُ الْعِلْمِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "غرر الحكم",
    "reference": ""
  },
  {
    "id": 107,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ أَطْعَمَ لِسَانَهُ النَّاسَ أَكَلَهُ الْكِلَابُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 108,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "صَلَاةُ الرَّجُلِ خَلْفَ الْفَاجِرِ كَصَلَاةِ الرَّجُلِ خَلْفَ الْبَارِّ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "تفسير العياشي",
    "reference": ""
  },
  {
    "id": 109,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "كُلُّ عِلْمٍ فِي الْخَطَرِ الْعَظِيمِ بَاطِلٌ إِلَّا عِلْمُ الدِّينِ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 110,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "مَنْ كَانَ يُؤْمِنُ بِاللَّهِ فَلْيَأَنَسْ بِالْوَحْدَةِ مَعَ اللَّهِ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 111,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "مَنْ عَرَفَ نَفْسَهُ عَرَفَ رَبَّهُ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 112,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "لَا يَذْهَبُ الْعِلْمُ إِلَّا بِذَهَابِ الْحَيَاءِ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 113,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "الْغُضُّ مِنَ الْبَصَرِ عَنْ مَحَارِمِ اللَّهِ أَشَدُّ مِنَ النَّظَرِ إِلَيْهَا",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 114,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "الْمُؤْمِنُ لَا يُصْبِحُ وَلَا يُمْسِي إِلَّا وَنِيَّتُهُ فِي قَلْبِهِ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 115,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "لَيْسَ الْعِلْمُ بِالتَّعْلِيمِ إِنَّمَا الْعِلْمُ نُورٌ يَقَعُ فِي الْقَلْبِ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 116,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "إِنَّ اللَّهَ يُحِبُّ الْفَرَحَ فِي الْخَيْرِ وَيُبْغِضُ الْحُزْنَ فِي الْخَيْرِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 117,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "إِنَّ الْإِنْسَانَ يُولَدُ مَرَّةً وَيَحْيَا مَرَّةً وَلَكِنَّهُ يَمُوتُ كَثِيراً",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 118,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "الْحَقُّ لَا يُعْرَفُ بِالرِّجَالِ بَلِ الرِّجَالُ يُعْرَفُونَ بِالْحَقِّ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "المدرسة القرآنية",
    "reference": ""
  },
  {
    "id": 119,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "التَّزَامُ الْقِيمَ الْأَخْلَاقِيَّةِ هُوَ ضَمَانُ اسْتِقْرَارِ الْمُجْتَمَعِ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 120,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "إِنَّ الْقُرْآنَ يُخَاطِبُنَا فِي كُلِّ عَصْرٍ بِلُغَةِ الْحَيَاةِ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 121,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "الاِسْتِكْبَارُ عَلَى الْحَقِّ هُوَ أُسَاسُ كُلِّ شَرٍّ فِي الْأَرْضِ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 122,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "إِنَّمَا تَتَحَقَّقُ الْأُمَّةُ بِالْوَعْيِ وَالْعَمَلِ",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 123,
    "category": "نهج البلاغة",
    "categoryId": "nahjul_balagha",
    "text": "فَإِنَّ تَقْوَى اللَّهِ دَوَاءُ دَاءِ قُلُوبِكُمْ وَبَصَرُ عَمَى أَفْئِدَتِكُمْ",
    "narrator": "من خطبة أمير المؤمنين (ع)",
    "source": "نهج البلاغة",
    "reference": "الخطبة 183"
  },
  {
    "id": 124,
    "category": "نهج البلاغة",
    "categoryId": "nahjul_balagha",
    "text": "أَيُّهَا النَّاسُ، إِنَّكُمْ فِي دَارِ مَمَرٍّ وَالْآخِرَةُ دَارُ مُسْتَقَرٍّ",
    "narrator": "من خطبة أمير المؤمنين (ع)",
    "source": "نهج البلاغة",
    "reference": "الخطبة 204"
  },
  {
    "id": 125,
    "category": "نهج البلاغة",
    "categoryId": "nahjul_balagha",
    "text": "الدُّنْيَا دَارُ بَلَاءٍ وَالْآخِرَةُ دَارُ جَزَاءٍ",
    "narrator": "من خطبة أمير المؤمنين (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 433"
  },
  {
    "id": 126,
    "category": "نهج البلاغة",
    "categoryId": "nahjul_balagha",
    "text": "فَوَ اللَّهِ لَابْنُ أَبِي طَالِبٍ آنَسُ بِالْمَوْتِ مِنَ الطِّفْلِ بِثَدْيِ أُمِّهِ",
    "narrator": "من خطبة أمير المؤمنين (ع)",
    "source": "نهج البلاغة",
    "reference": "الخطبة 5"
  },
  {
    "id": 127,
    "category": "نهج البلاغة",
    "categoryId": "nahjul_balagha",
    "text": "مَا أَحْسَنَ تَوَاضُعَ الْأَغْنِيَاءِ لِلْفُقَرَاءِ طَلَباً لِمَا عِنْدَ اللَّهِ",
    "narrator": "من كلام أمير المؤمنين (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 128,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "إِنَّ الْأُمَّةَ لَا تَنْهَضُ إِلَّا بِالْعِلْمِ وَالْعَمَلِ وَالْجِهَادِ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 129,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "الْإِيمَانُ لَيْسَ كَلِمَةً تُقَالُ بَلْ حَقِيقَةٌ تُعَاشُ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 130,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "لَا يُوجَدُ حَاجِزٌ بَيْنَ الْإِنْسَانِ وَاللَّهِ سِوَى الْغَفْلَةِ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 131,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "قَالَ رَسُولُ اللَّهِ (ص): إِنِّي تَارِكٌ فِيكُمُ الثَّقَلَيْنِ: كِتَابَ اللَّهِ وَعِتْرَتِي أَهْلَ بَيْتِي",
    "narrator": "الإمام علي بن أبي طالب (ع) عن النبي (ص)",
    "source": "حديث الثقلين",
    "reference": ""
  },
  {
    "id": 132,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "كُلُّ وِعَاءٍ يَضِيقُ بِمَا جُعِلَ فِيهِ إِلَّا وِعَاءَ الْعِلْمِ فَإِنَّهُ يَتَّسِعُ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": "الحكمة 158"
  },
  {
    "id": 133,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "رَأْسُ الْعِبَادَةِ مَعْرِفَةُ اللَّهِ وَالتَّسْلِيمُ لَهُ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 134,
    "category": "الإمام الرضا (ع)",
    "categoryId": "imam_ridha",
    "text": "الْعِبَادَةُ لَيْسَتْ كَثْرَةَ الصِّيَامِ وَالصَّلَاةِ بَلْ كَثْرَةَ التَّفَكُّرِ",
    "narrator": "الإمام علي بن موسى الرضا (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 135,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الْأَنَاةُ وَالسَّكِينَةُ وَالْوَقَارُ مِنْ أَخْلَاقِ الْأَنْبِيَاءِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "غرر الحكم",
    "reference": ""
  },
  {
    "id": 136,
    "category": "الإمام الباقر (ع)",
    "categoryId": "imam_baqir",
    "text": "لَا يَكُونُ الرَّجُلُ عَالِماً حَتَّى لَا يَحْسُدَ مَنْ فَوْقَهُ",
    "narrator": "الإمام محمد الباقر (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 137,
    "category": "الإمام الحسن (ع)",
    "categoryId": "imam_hasan",
    "text": "إِنَّ أَفْضَلَ النَّاسِ مَنْ تَوَاضَعَ عَنْ رِفْعَةٍ",
    "narrator": "الإمام الحسن المجتبى (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 138,
    "category": "الإمام الحسين (ع)",
    "categoryId": "imam_hussein",
    "text": "مَنْ جَادَ سَادَ وَمَنْ بَخِلَ رَذِلَ",
    "narrator": "الإمام الحسين بن علي (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 139,
    "category": "الإمام زين العابدين (ع)",
    "categoryId": "imam_zainulabideen",
    "text": "لَا تَحْمِلْ لِلْمَوْتِ هَمّاً فَإِنَّهُ آتِيكَ لَا مَحَالَةَ",
    "narrator": "الإمام علي بن الحسين زين العابدين (ع)",
    "source": "الصحيفة السجادية",
    "reference": ""
  },
  {
    "id": 140,
    "category": "الإمام الصادق (ع)",
    "categoryId": "imam_sadiq",
    "text": "الْمُؤْمِنُ قَبْلَ الْإِحْسَانِ لَا يُحْسِنُ الْجَزَاءَ",
    "narrator": "الإمام جعفر الصادق (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 141,
    "category": "الإمام الكاظم (ع)",
    "categoryId": "imam_kadhim",
    "text": "إِنَّ اللَّهَ يَقْبَلُ الدُّعَاءَ مِنَ الْأَبْرَارِ وَيَنْظُرُ إِلَى الْمُذْنِبِينَ",
    "narrator": "الإمام موسى الكاظم (ع)",
    "source": "موسوعة أقوال الأئمة",
    "reference": ""
  },
  {
    "id": 142,
    "category": "السيد محمد حسين فضل الله",
    "categoryId": "fadlallah",
    "text": "الْحُرِّيَّةُ هِيَ الْإِطَارُ الَّذِي تُحَقَّقُ فِيهِ إِنْسَانِيَّةُ الْإِنْسَانِ",
    "narrator": "السيد محمد حسين فضل الله",
    "source": "تفسير من وحي القرآن",
    "reference": ""
  },
  {
    "id": 143,
    "category": "السيد محمد باقر الصدر",
    "categoryId": "sadr",
    "text": "الْأَمَلُ هُوَ الْجَنَاحُ الَّذِي يُحَلِّقُ بِالْإِنْسَانِ إِلَى الْمُسْتَقْبَلِ",
    "narrator": "الشهيد السيد محمد باقر الصدر",
    "source": "فلسفتنا",
    "reference": ""
  },
  {
    "id": 144,
    "category": "السيد السيستاني",
    "categoryId": "sistani",
    "text": "عَلَى الْمُؤْمِنِ أَنْ يَكُونَ مُتَوَاضِعاً فِي حَيَاتِهِ مُتَسَامِحاً فِي مُعَامَلَاتِهِ",
    "narrator": "السيد علي السيستاني",
    "source": "البیانات",
    "reference": ""
  },
  {
    "id": 145,
    "category": "السيد محمد باقر الحكيم",
    "categoryId": "hakim",
    "text": "الْعِلْمُ الْحَقِيقِيُّ هُوَ مَا يُقَرِّبُ الْإِنْسَانَ مِنْ رَبِّهِ",
    "narrator": "السيد محمد باقر الحكيم",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 146,
    "category": "حكم وأقوال العلماء",
    "categoryId": "scholars",
    "text": "إِنَّ الْإِيمَانَ لَا يَكْتَمِلُ حَتَّى تَكُونَ الرَّحْمَةُ فِي الْقَلْبِ",
    "narrator": "الشيخ محمد حسين كاشف الغطاء",
    "source": "موسوعة الحكم",
    "reference": ""
  },
  {
    "id": 147,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الْجَاهِلُ مَنْ لَمْ يَتَعَلَّمْ مِنْ زَمَانِهِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 148,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ تَكَلَّمَ بِالْعِلْمِ وُقِّرَ وَمَنْ تَكَلَّمَ بِالْجَهْلِ ازْدُرِيَ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 149,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "الظَّفَرُ بِالْحِلْمِ وَالنَّصْرُ بِالْعِلْمِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "نهج البلاغة",
    "reference": ""
  },
  {
    "id": 150,
    "category": "الإمام علي (ع)",
    "categoryId": "imam_ali",
    "text": "مَنْ لَمْ يَتَعَلَّمْ فِي الصِّغَرِ لَمْ يَتَقَدَّمْ فِي الْكِبَرِ",
    "narrator": "الإمام علي بن أبي طالب (ع)",
    "source": "غرر الحكم",
    "reference": ""
  }
]
