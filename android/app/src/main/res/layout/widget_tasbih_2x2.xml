<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark_tasbih"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Dhikr Name -->
    <TextView
        android:id="@+id/widget_tasbih_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="سبحان الله"
        android:textColor="@color/widget_gold"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Count -->
    <TextView
        android:id="@+id/widget_tasbih_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:gravity="center"
        android:text="٠"
        android:textColor="@color/widget_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Target -->
    <TextView
        android:id="@+id/widget_tasbih_target"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="/ ٣٣"
        android:textColor="@color/widget_text_muted"
        android:textSize="11sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/widget_divider_h" />

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Increment Button -->
        <LinearLayout
            android:id="@+id/widget_btn_increment"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_btn_increment"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textColor="@color/widget_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Reset Button -->
        <LinearLayout
            android:id="@+id/widget_btn_reset"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_btn_reset"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↺"
                android:textColor="@color/widget_gold_dim"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
