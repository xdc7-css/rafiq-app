<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top Row: Next Prayer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_prayer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☪ الصلاة القادمة"
                android:textColor="@color/widget_gold"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_next_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الفجر"
                android:textColor="@color/widget_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_next_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٤:٣٠"
                android:textColor="@color/widget_gold"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_countdown_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المتبقي"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١:٤٥"
                android:textColor="@color/widget_gold_accent"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_divider_h" />

    <!-- Bottom Row: All Prayer Times -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_fajr_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الفجر"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_fajr_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_dhuhr_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الظهر"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_dhuhr_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_asr_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="العصر"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_asr_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_maghrib_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="المغرب"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_maghrib_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_isha_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="العشاء"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_isha_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
